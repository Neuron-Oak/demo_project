    "url": "git+https://github.com/Neuron-Oak/demo_project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Neuron-Oak/demo_project/issues"
  },
  "homepage": "https://github.com/Neuron-Oak/demo_project#readme",
  "jest-junit": {
    "outputDirectory": "test-results/frontend",
    "outputName": "junit.xml"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0"
  }
